# =============================================================================
# Supabase Database Connection
# Get these from: Supabase Dashboard > Project Settings > Database
# =============================================================================

# Pooled connection (port 6543) — used by your app at runtime
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (port 5432) — used by Prisma for migrations
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# =============================================================================
# Supabase API
# Get these from: Supabase Dashboard > Project Settings > API
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# Service Role Key — used ONLY by the seed script (never exposed to the browser)
# Get this from: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# Seed password — used by `npm run db:seed` to create initial auth users
SEED_PASSWORD="your-seed-password-here"

# =============================================================================
# Cron / Scheduled Jobs
# =============================================================================

# Secret for authenticating cron job endpoints (used by /api/ar/jobs/mark-overdue)
# Generate with: openssl rand -base64 32
CRON_SECRET="generate-a-random-secret-here"
