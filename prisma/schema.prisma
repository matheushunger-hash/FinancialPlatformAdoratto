// =============================================================================
// Prisma Schema — Financial Platform Adoratto
// =============================================================================
// This file defines the shape of your database. Every table, column,
// relationship, and index is declared here. When you run `prisma migrate dev`,
// Prisma reads this file and generates the SQL to create/update your database.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// Enums — fixed lists of allowed values
// =============================================================================
// Instead of storing "ADMIN" as a plain string (where a typo like "admin"
// could sneak in), the database enforces that the value MUST be one of these.
// =============================================================================

enum Role {
  ADMIN
  USER
}

enum DocumentType {
  CNPJ
  CPF
}

enum PayableStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  BOLETO
  PIX
  TRANSFERENCIA
  CARTAO
  DINHEIRO
  CHEQUE
}

enum PayableCategory {
  REVENDA
  DESPESA
}

// =============================================================================
// Tables
// =============================================================================

/// User profile — synced with Supabase Auth.
/// The `id` here MUST match the UUID from auth.users.
model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  name      String
  role      Role     @default(USER)
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // A user "has many" suppliers and payables
  suppliers Supplier[]
  payables  Payable[]

  @@map("users")
}

/// Companies or people the user pays (fornecedores).
model Supplier {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  name         String
  documentType DocumentType @map("document_type")
  document     String       // CPF or CNPJ — stored as raw digits only
  tradeName    String?      @map("trade_name") // Nome fantasia
  contactName  String?      @map("contact_name")
  email        String?
  phone        String?
  bankName     String?      @map("bank_name")
  bankAgency   String?      @map("bank_agency")
  bankAccount  String?      @map("bank_account")
  pixKey       String?      @map("pix_key")
  notes        String?
  active       Boolean      @default(true) // Soft delete flag
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payables Payable[]

  // Unique constraint: no two suppliers can share the same CPF/CNPJ
  @@unique([document], map: "idx_suppliers_doc")
  @@map("suppliers")
}

/// Bills and invoices — the core entity of the platform (contas a pagar).
model Payable {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String          @map("user_id") @db.Uuid
  supplierId    String          @map("supplier_id") @db.Uuid
  description   String
  amount        Decimal         @db.Decimal(12, 2) // Valor original
  payValue      Decimal         @map("pay_value") @db.Decimal(12, 2) // Valor a pagar
  issueDate     DateTime        @map("issue_date") @db.Date // Data de entrada
  dueDate       DateTime        @map("due_date") @db.Date
  status        PayableStatus   @default(PENDING)
  category      PayableCategory
  paymentMethod PaymentMethod   @map("payment_method")
  invoiceNumber String?         @map("invoice_number") // Número NF-e
  tags          String[]        @default([]) // Multi-select labels
  notes         String?
  paidAt        DateTime?       @map("paid_at") @db.Timestamptz
  approvedBy    String?         @map("approved_by") @db.Uuid
  approvedAt    DateTime?       @map("approved_at") @db.Timestamptz
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  supplier    Supplier     @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  attachments Attachment[]

  // Indexes — each speeds up a different common query
  @@index([dueDate], map: "idx_payables_due")
  @@index([supplierId], map: "idx_payables_supplier")
  @@index([status], map: "idx_payables_status")
  @@index([category], map: "idx_payables_category")
  @@map("payables")
}

/// Files attached to payables (receipts, invoices, contracts).
model Attachment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payableId String   @map("payable_id") @db.Uuid
  fileName  String   @map("file_name")
  fileUrl   String   @map("file_url") // path inside the Storage bucket
  fileSize  Int      @map("file_size") // size in bytes
  mimeType  String   @map("mime_type") // e.g. "application/pdf"
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relationships
  payable Payable @relation(fields: [payableId], references: [id], onDelete: Cascade)

  @@map("attachments")
}
