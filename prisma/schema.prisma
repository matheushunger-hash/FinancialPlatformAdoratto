// =============================================================================
// Prisma Schema — Financial Platform Adoratto
// =============================================================================
// This file defines the shape of your database. Every table, column,
// relationship, and index is declared here. When you run `prisma migrate dev`,
// Prisma reads this file and generates the SQL to create/update your database.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// Enums — fixed lists of allowed values
// =============================================================================
// Instead of storing "ADMIN" as a plain string (where a typo like "admin"
// could sneak in), the database enforces that the value MUST be one of these.
// =============================================================================

enum Role {
  ADMIN
  USER
}

enum DocumentType {
  CNPJ
  CPF
}

enum PayableStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  BOLETO
  PIX
  TRANSFERENCIA
  CARTAO
  DINHEIRO
  CHEQUE
}

enum PayableCategory {
  REVENDA
  DESPESA
}

enum Frequency {
  WEEKLY
  MONTHLY
  YEARLY
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  DIVERGENT
  OVERDUE
  CANCELLED
}

// =============================================================================
// Tables
// =============================================================================

/// Organization — groups users who share the same data.
/// All read queries scope by tenantId so everyone in the org sees the same records.
model Tenant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  users              User[]
  suppliers          Supplier[]
  payables           Payable[]
  recurringPayables  RecurringPayable[]
  importBatches      ImportBatch[]
  cardTransactions   CardTransaction[]
  paymentReceipts    PaymentReceipt[]
  auditLogs          AuditLog[]
  settings           TenantSettings?

  @@map("tenants")
}

/// User profile — synced with Supabase Auth.
/// The `id` here MUST match the UUID from auth.users.
model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  name      String
  role      Role     @default(USER)
  avatarUrl String?  @map("avatar_url")
  tenantId  String   @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  suppliers          Supplier[]
  payables           Payable[]
  recurringPayables  RecurringPayable[]
  importBatches      ImportBatch[]
  paymentReceipts    PaymentReceipt[]
  auditLogs          AuditLog[]

  @@map("users")
}

/// Companies or people the user pays (fornecedores).
model Supplier {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  name         String
  documentType DocumentType @map("document_type")
  document     String       // CPF or CNPJ — stored as raw digits only
  tradeName    String?      @map("trade_name") // Nome fantasia
  contactName  String?      @map("contact_name")
  email        String?
  phone        String?
  bankName     String?      @map("bank_name")
  bankAgency   String?      @map("bank_agency")
  bankAccount  String?      @map("bank_account")
  pixKey       String?      @map("pix_key")
  notes        String?
  active       Boolean      @default(true) // Soft delete flag
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  payables          Payable[]
  recurringPayables RecurringPayable[]

  // Unique constraint: no two suppliers in the same tenant can share the same CPF/CNPJ
  @@unique([tenantId, document], map: "idx_suppliers_tenant_doc")
  @@map("suppliers")
}

/// Bills and invoices — the core entity of the platform (contas a pagar).
model Payable {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String          @map("user_id") @db.Uuid
  tenantId      String          @map("tenant_id") @db.Uuid
  supplierId    String?         @map("supplier_id") @db.Uuid
  payee         String?         @map("payee") // Free-text payee name (when no formal supplier)
  description   String
  amount        Decimal         @db.Decimal(12, 2) // Valor original
  payValue      Decimal         @map("pay_value") @db.Decimal(12, 2) // Valor a pagar
  jurosMulta    Decimal?        @default(0) @map("juros_multa") @db.Decimal(12, 2) // Juros/Multa (payValue - amount)
  issueDate     DateTime        @map("issue_date") @db.Date // Data de entrada
  dueDate       DateTime        @map("due_date") @db.Date
  status        PayableStatus   @default(PENDING)
  category      PayableCategory
  paymentMethod PaymentMethod   @map("payment_method")
  invoiceNumber String?         @map("invoice_number") // Número NF-e
  tags          String[]        @default([]) // Multi-select labels
  notes         String?
  paidAt        DateTime?       @map("paid_at") @db.Timestamptz
  approvedBy    String?         @map("approved_by") @db.Uuid
  approvedAt    DateTime?       @map("approved_at") @db.Timestamptz
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  supplier    Supplier?    @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  attachments Attachment[]

  // Indexes — each speeds up a different common query
  @@index([tenantId], map: "idx_payables_tenant")
  @@index([dueDate], map: "idx_payables_due")
  @@index([supplierId], map: "idx_payables_supplier")
  @@index([status], map: "idx_payables_status")
  @@index([category], map: "idx_payables_category")
  @@map("payables")
}

/// Files attached to payables (receipts, invoices, contracts).
model Attachment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payableId String   @map("payable_id") @db.Uuid
  fileName  String   @map("file_name")
  fileUrl   String   @map("file_url") // path inside the Storage bucket
  fileSize  Int      @map("file_size") // size in bytes
  mimeType  String   @map("mime_type") // e.g. "application/pdf"
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relationships
  payable Payable @relation(fields: [payableId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

/// Recurring payment templates — generates Payable records on a schedule.
model RecurringPayable {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String          @map("user_id") @db.Uuid
  tenantId        String          @map("tenant_id") @db.Uuid
  supplierId      String          @map("supplier_id") @db.Uuid
  description     String
  amount          Decimal         @db.Decimal(12, 2)
  category        PayableCategory
  paymentMethod   PaymentMethod   @map("payment_method")
  frequency       Frequency
  dayOfMonth      Int?            @map("day_of_month") // 1–28, only for MONTHLY
  startDate       DateTime        @map("start_date") @db.Date
  endDate         DateTime?       @map("end_date") @db.Date
  active          Boolean         @default(true)
  lastGeneratedAt DateTime?       @map("last_generated_at") @db.Timestamptz
  tags            String[]        @default([])
  notes           String?
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  @@index([tenantId], map: "idx_recurring_tenant")
  @@index([active], map: "idx_recurring_active")
  @@map("recurring_payables")
}

// =============================================================================
// AR Module — Accounts Receivable (card transactions & reconciliation)
// =============================================================================

/// Tracks each RPInfo spreadsheet import with row counts and totals.
model ImportBatch {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  filename     String
  totalRows    Int      @map("total_rows")
  acceptedRows Int      @map("accepted_rows")
  rejectedRows Int      @map("rejected_rows")
  grossTotal   Decimal  @map("gross_total") @db.Decimal(12, 2)
  netTotal     Decimal  @map("net_total") @db.Decimal(12, 2)
  dateFrom     DateTime @map("date_from") @db.Date
  dateTo       DateTime @map("date_to") @db.Date
  importedAt   DateTime @default(now()) @map("imported_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  cardTransactions CardTransaction[]

  @@index([tenantId], map: "idx_import_batches_tenant")
  @@map("import_batches")
}

/// Individual card transactions imported from RPInfo spreadsheets.
model CardTransaction {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String            @map("tenant_id") @db.Uuid
  importBatchId       String            @map("import_batch_id") @db.Uuid
  transactionId       String            @map("transaction_id")
  transactionDate     DateTime          @map("transaction_date") @db.Date
  expectedPaymentDate DateTime          @map("expected_payment_date") @db.Date
  brand               String
  acquirer            String
  modality            String
  grossAmount         Decimal           @map("gross_amount") @db.Decimal(12, 2)
  netAmount           Decimal           @map("net_amount") @db.Decimal(12, 2)
  feeAmount           Decimal           @map("fee_amount") @db.Decimal(12, 2)
  feePct              Decimal           @map("fee_pct") @db.Decimal(6, 4)
  nsu                 String
  unitCode            String            @map("unit_code")
  unitName            String            @map("unit_name")
  installment         Int               @default(1)
  totalInstallments   Int               @map("total_installments") @default(1)
  status              TransactionStatus @default(PENDING)
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  importBatch     ImportBatch      @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  paymentReceipts PaymentReceipt[]

  @@unique([tenantId, transactionId], map: "idx_card_tx_tenant_txid")
  @@index([tenantId], map: "idx_card_tx_tenant")
  @@index([expectedPaymentDate], map: "idx_card_tx_expected_date")
  @@index([status], map: "idx_card_tx_status")
  @@index([brand], map: "idx_card_tx_brand")
  @@index([transactionDate], map: "idx_card_tx_date")
  @@map("card_transactions")
}

/// Records when payment is received for a card transaction.
model PaymentReceipt {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  cardTransactionId String   @map("card_transaction_id") @db.Uuid
  registeredById    String   @map("registered_by_id") @db.Uuid
  receivedAt        DateTime @map("received_at") @db.Date
  receivedAmount    Decimal  @map("received_amount") @db.Decimal(12, 2)
  divergence        Decimal  @db.Decimal(12, 2)
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  cardTransaction CardTransaction @relation(fields: [cardTransactionId], references: [id], onDelete: Cascade)
  registeredBy    User            @relation(fields: [registeredById], references: [id])

  @@index([tenantId], map: "idx_payment_receipts_tenant")
  @@index([cardTransactionId], map: "idx_payment_receipts_tx")
  @@map("payment_receipts")
}

/// Generic audit log for change tracking with before/after snapshots.
model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  before     Json?
  after      Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_audit_log_tenant")
  @@index([entityType, entityId], map: "idx_audit_log_entity")
  @@index([userId], map: "idx_audit_log_user")
  @@map("audit_log")
}

/// Per-tenant configuration — spending limits, notification preferences, etc.
model TenantSettings {
  id                 String   @id @default(cuid())
  tenantId           String   @unique @map("tenant_id") @db.Uuid
  buyerSpendingLimit Decimal  @default(350000) @map("buyer_spending_limit") @db.Decimal(15, 2)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("tenant_settings")
}
