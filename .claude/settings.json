{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-commit-tsc.sh",
            "description": "Type-check before every git commit"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/kill-stale-server.sh",
            "description": "Kill stale dev server before npm run dev"
          }
        ]
      }
    ]
  }
}
